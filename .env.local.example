# Dashboard Supabase -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Mot de passe de la base (non utilisé par l'app, conservé pour référence)
SUPABASE_DB_PASSWORD=

# console.anthropic.com -> API Keys (secret serveur, ne jamais exposer au navigateur)
ANTHROPIC_API_KEY=

# true = l'analyse renvoie un texte simule, sans appeler l'API (tests gratuits)
ANTHROPIC_MOCK=

# Tests E2E (npm run test:e2e)
# URL cible des tests (defaut : prod). Pointera vers l'environnement de test plus tard.
E2E_BASE_URL=
# Compte utilise par les tests (les tests ne touchent que des donnees prefixees [TEST])
TEST_USER_EMAIL=
TEST_USER_PASSWORD=
